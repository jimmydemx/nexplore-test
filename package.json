{
    "name": "nexplore-test",
    "private": true,
    "packageManager": "pnpm@10.0.0",
    "scripts": {
        "build:types": "corepack pnpm --filter @nexplore-test/shared-types build",
        "build:utils": "corepack pnpm --filter @nexplore-test/shared-utils build",
        "dev:react": "corepack pnpm --filter @nexplore-test/frontend dev",
        "build:react": "corepack pnpm --filter @nexplore-test/frontend build",
        "dev:backend": "corepack pnpm --filter @nexplore-test/backend start:dev",
        "dev:backend:prod": "corepack pnpm --filter @nexplore-test/backend start:prod",
        "build:backend": "corepack pnpm --filter @nexplore-test/backend build"
    },
    "dependencies": {
        "@nexplore-test/shared-types": "workspace:*",
        "@nexplore-test/shared-utils": "workspace:*"
    },
    "devDependencies": {
        "ts-node": "^10.9.2"
    }
}