{
    "compilerOptions": {
        "module": "node16",
        "moduleResolution": "node16",
        "esModuleInterop": true,
        "declaration": true,
        "removeComments": true,
        "target": "ES2021",
        "sourceMap": true,
        "outDir": "dist",
        "rootDir": "src",
        "skipLibCheck": true,
        "strict": true
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}